<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="750.0" spacing="20.0" stylesheets="@../styles/main.css" styleClass="main-container" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.acculab.controllers.PacientesController">
   <padding>
      <Insets bottom="20.0" left="30.0" right="30.0" top="30.0" />
   </padding>

   <Label styleClass="title-label" text="Gestión de Pacientes" />

   <HBox spacing="20.0">
      <VBox prefWidth="350.0" spacing="15.0" styleClass="info-box">
         <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2c3e50;" text="Datos del Paciente" />
         
         <VBox spacing="5.0">
            <Label styleClass="info-label" text="Nombres:" />
            <TextField fx:id="txtNombres" />
         </VBox>
         
         <VBox spacing="5.0">
            <Label styleClass="info-label" text="Apellidos:" />
            <TextField fx:id="txtApellidos" />
         </VBox>
         
         <HBox spacing="15.0">
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <Label styleClass="info-label" text="Teléfono:" />
               <TextField fx:id="txtTelefono" />
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <Label styleClass="info-label" text="Correo Electrónico:" />
               <TextField fx:id="txtCorreo" />
            </VBox>
         </HBox>
         
         <HBox spacing="15.0">
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <Label styleClass="info-label" text="Fecha de Nacimiento:" />
               <DatePicker fx:id="dpFechaNacimiento" maxWidth="Infinity" />
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <Label styleClass="info-label" text="Sexo:" />
               <ComboBox fx:id="cbSexo" maxWidth="Infinity" />
            </VBox>
         </HBox>
         
         <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <Button mnemonicParsing="false" onAction="#limpiarFormulario" text="Limpiar" style="-fx-background-color: #bdc3c7; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Button mnemonicParsing="false" onAction="#eliminarPaciente" text="Eliminar" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
            <Button mnemonicParsing="false" onAction="#guardarPaciente" text="Guardar" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
         </HBox>
      </VBox>
      
      <VBox HBox.hgrow="ALWAYS" spacing="10.0">
         <Label text="Buscador" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
         <TextField fx:id="txtBuscar" promptText="Buscar por nombre o apellido..." style="-fx-pref-height: 35px;" />
         <Label text="* Seleccione un paciente en la tabla para editarlo o eliminarlo" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;"/>
      </VBox>
   </HBox>

   <TableView fx:id="tablePacientes" VBox.vgrow="ALWAYS">
     <columns>
       <TableColumn fx:id="colNombres" prefWidth="150.0" text="Nombres" />
       <TableColumn fx:id="colApellidos" prefWidth="150.0" text="Apellidos" />
       <TableColumn fx:id="colTelefono" prefWidth="120.0" text="Teléfono" />
       <TableColumn fx:id="colCorreo" prefWidth="180.0" text="Correo" />
       <TableColumn fx:id="colFechaNac" prefWidth="120.0" text="F. Nacimiento" />
       <TableColumn fx:id="colSexo" prefWidth="90.0" text="Sexo" />
     </columns>
   </TableView>

</VBox>
