<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="750.0" spacing="20.0" stylesheets="@../styles/main.css" styleClass="main-container" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.acculab.controllers.OrdenesController">
   <padding>
      <Insets bottom="20.0" left="30.0" right="30.0" top="30.0" />
   </padding>

   <Label styleClass="title-label" text="Generación de Órdenes Médicas" />

   <HBox spacing="20.0" VBox.vgrow="ALWAYS">
      <VBox prefWidth="350.0" spacing="20.0">
         <VBox spacing="15.0" styleClass="info-box">
            <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2c3e50;" text="1. Datos Generales" />
            <VBox spacing="5.0">
               <Label styleClass="info-label" text="Buscar Paciente:" />
               <TextField fx:id="txtBuscarPaciente" promptText="Escriba para filtrar pacientes..." />
               <ComboBox fx:id="cbPacientes" maxWidth="Infinity" promptText="Seleccionar Paciente..." />
            </VBox>
            <VBox spacing="5.0">
               <Label styleClass="info-label" text="Médico Solicitante:" />
               <TextField fx:id="txtMedico" promptText="Nombre del Médico" />
            </VBox>
         </VBox>
         
         <VBox spacing="15.0" styleClass="info-box">
            <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2c3e50;" text="2. Catálogo de Pruebas" />
            
            <VBox spacing="10.0">
               <Label styleClass="info-label" text="Prueba Individual:" />
               <HBox spacing="10.0">
                  <ComboBox fx:id="cbPruebas" maxWidth="Infinity" promptText="Seleccione prueba..." HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnAgregarPrueba" mnemonicParsing="false" onAction="#agregarPruebaAOrden" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="➕ Añadir" />
               </HBox>
            </VBox>
            <VBox spacing="10.0">
               <Label styleClass="info-label" text="Perfil Compuesto:" />
               <HBox spacing="10.0">
                  <ComboBox fx:id="cbPerfiles" maxWidth="Infinity" promptText="Seleccione perfil..." HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnAgregarPerfil" mnemonicParsing="false" onAction="#agregarPerfilAOrden" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="➕ Añadir" />
               </HBox>
            </VBox>
         </VBox>
      </VBox>

      <VBox HBox.hgrow="ALWAYS" spacing="10.0" styleClass="info-box">
         <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2c3e50;" text="3. Pruebas Seleccionadas" />
         
         <TableView fx:id="tablePruebasSeleccionadas" VBox.vgrow="ALWAYS">
           <columns>
             <TableColumn fx:id="colNombrePrueba" prefWidth="300.0" text="Nombre de la Prueba" />
           </columns>
         </TableView>
         
         <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Button mnemonicParsing="false" onAction="#eliminarPruebaSeleccionada" text="Eliminar de la lista" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px;" />
            <Label fx:id="lblTotalPruebas" text="Total Pruebas: 0" style="-fx-font-weight: bold; -fx-text-fill: #34495e;" />
         </HBox>
         
         <Button mnemonicParsing="false" onAction="#guardarOrden" text="Generar y Guardar Orden" maxWidth="Infinity" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10px; -fx-cursor: hand;" />
      </VBox>
   </HBox>
</VBox>
