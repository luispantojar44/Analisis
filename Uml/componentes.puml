@startuml
package "Capa de Presentación (JavaFX)" {
  [Controladores (Controllers)] as C
  [Vistas FXML] as V
}

package "Capa de Lógica de Negocio" {
  [Servicios (Services)] as S
  [Modelos (Entidades)] as M
}

package "Capa de Persistencia" {
  [DAO Genérico] as GDAO
  [DAOs Específicos] as DAO
}

database "Archivos Binarios (.bin)" as DB

V <..> C : Vinculación de Datos (Bindings)
C --> S : Invoca Lógica Compleja
C --> DAO : Operaciones CRUD simples
S --> DAO : Actualizaciones Transaccionales
DAO --> GDAO : Hereda Funciones
GDAO --> DB : Serialización I/O
C ..> M : Usa Entidades
S ..> M : Manipula Entidades
@enduml
