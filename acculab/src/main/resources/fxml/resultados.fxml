<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.acculab.controllers.ResultadosController" stylesheets="@../styles/main.css" styleClass="main-container">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Captura de Resultados" styleClass="title-label"/>
    
    <VBox spacing="5" styleClass="info-box">
        <Label fx:id="lblPaciente" text="Paciente: " styleClass="info-label"/>
        <Label fx:id="lblOrden" text="Orden N°: " styleClass="info-label"/>
    </VBox>

    <TableView fx:id="tableResultados" VBox.vgrow="ALWAYS" editable="true">
        <columns>
            <TableColumn fx:id="colPrueba" text="Prueba" prefWidth="200" editable="false"/>
            <TableColumn fx:id="colReferencia" text="Ref. (Min - Max)" prefWidth="150" editable="false"/>
            <TableColumn fx:id="colResultado" text="Resultado (Doble Clic)" prefWidth="150" />
            <TableColumn fx:id="colAlerta" text="Alerta Visual" prefWidth="150" editable="false"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER" spacing="15.0">
        <Button mnemonicParsing="false" onAction="#guardarResultados" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px 20px; -fx-cursor: hand;" text="Guardar Resultados" />
        
        <!-- Nuevos botones de Exportación (Strategy) -->
        <Button mnemonicParsing="false" onAction="#generarPDFMembretado" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px 20px; -fx-cursor: hand;" text="📄 PDF Membretado" />
        <Button mnemonicParsing="false" onAction="#generarPDFSinMembrete" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px 20px; -fx-cursor: hand;" text="📄 PDF Simple" />
        <Button mnemonicParsing="false" onAction="#generarPDFConvenio" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px 20px; -fx-cursor: hand;" text="📄 PDF Convenio" />
        
        <!-- Botón para modificar la orden -->
        <Button mnemonicParsing="false" onAction="#modificarOrden" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px 20px; -fx-cursor: hand;" text="✏️ Modificar Orden" />
    </HBox>
</VBox>
