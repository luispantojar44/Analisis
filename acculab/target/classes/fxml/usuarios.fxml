<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="750.0" spacing="20.0" stylesheets="@../styles/main.css" styleClass="main-container" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.acculab.controllers.UsuariosController">
   <padding>
      <Insets bottom="20.0" left="30.0" right="30.0" top="30.0" />
   </padding>

   <Label styleClass="title-label" text="Gestión de Usuarios" />

   <HBox spacing="20.0">
      <VBox prefWidth="350.0" spacing="15.0" styleClass="info-box">
         <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2c3e50;" text="Datos del Usuario" />
         
         <VBox spacing="5.0">
            <Label styleClass="info-label" text="Nombre Completo:" />
            <TextField fx:id="txtNombre" />
         </VBox>
         
         <VBox spacing="5.0">
            <Label styleClass="info-label" text="Nombre de Usuario (Username):" />
            <TextField fx:id="txtUsername" />
         </VBox>
         
         <VBox spacing="5.0">
            <Label styleClass="info-label" text="Contraseña:" />
            <PasswordField fx:id="txtPassword" />
         </VBox>
         
         <VBox spacing="5.0">
            <Label styleClass="info-label" text="Rol del Sistema:" />
            <ComboBox fx:id="cbRol" maxWidth="Infinity" />
         </VBox>
         
         <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <Button mnemonicParsing="false" onAction="#limpiarFormulario" text="Limpiar" style="-fx-background-color: #bdc3c7; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Button mnemonicParsing="false" onAction="#eliminarUsuario" text="Desactivar" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
            <Button mnemonicParsing="false" onAction="#guardarUsuario" text="Guardar" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
         </HBox>
      </VBox>
      
      <VBox HBox.hgrow="ALWAYS" spacing="10.0">
         <Label text="Buscador" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
         <TextField fx:id="txtBuscar" promptText="Buscar por nombre o username..." style="-fx-pref-height: 35px;" />
         <Label text="* Seleccione un usuario en la tabla para editarlo" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;"/>
      </VBox>
   </HBox>

   <TableView fx:id="tableUsuarios" VBox.vgrow="ALWAYS">
     <columns>
       <TableColumn fx:id="colNombre" prefWidth="200.0" text="Nombre Completo" />
       <TableColumn fx:id="colUsername" prefWidth="150.0" text="Username" />
       <TableColumn fx:id="colRol" prefWidth="150.0" text="Rol" />
       <TableColumn fx:id="colEstado" prefWidth="100.0" text="Activo" />
     </columns>
   </TableView>

</VBox>
